# Copy this file to .env.local and fill in values.
# .env.local is gitignored; this file is committed.

# --- App ---
# In dev: http://localhost:3001 ; in prod: https://lacostagourmet.com
NEXT_PUBLIC_SITE_URL=

# --- Supabase ---
# From Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Authorize.net ---
# sandbox.authorize.net for dev, authorize.net for prod
AUTHNET_API_LOGIN_ID=
AUTHNET_TRANSACTION_KEY=
AUTHNET_SIGNATURE_KEY=
AUTHNET_ENVIRONMENT=sandbox
# Public client key for Accept.js hosted fields
NEXT_PUBLIC_AUTHNET_CLIENT_KEY=

# --- TaxJar (OPTIONAL v2 — not needed for launch; catalog is non-taxable grocery) ---
# TAXJAR_API_KEY=
# TAXJAR_FROM_ZIP=92009
# TAXJAR_FROM_STATE=CA

# --- QuickBooks Online ---
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
QBO_REALM_ID=
QBO_REFRESH_TOKEN=

# --- Resend (customer transactional email) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=customercare@lacostagourmet.com

# --- Order notification recipient (Jeff or whoever covers ops) ---
# Receives admin "new order" emails. Falls back to jeff@lacostagourmet.com.
ADMIN_NOTIFY_EMAIL=jeff@lacostagourmet.com

# --- Vercel Cron auth (abandoned-cart sender) ---
# Random 32+ char string. Vercel Cron sends this as `Authorization: Bearer ${CRON_SECRET}`.
# Generate locally with:  openssl rand -hex 32
CRON_SECRET=

# --- Google Workspace (vendor emails from grandpa's account) ---
# Option A: app password
GMAIL_SMTP_USER=
GMAIL_SMTP_APP_PASSWORD=
# Option B: OAuth (preferred)
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REFRESH_TOKEN=

# --- Admin bootstrap ---
# Comma-separated emails allowed to access /admin
ADMIN_EMAILS=
